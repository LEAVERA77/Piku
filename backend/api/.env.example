# Servidor
PORT=3000

# Base de datos Neon (pegá la URL real desde Neon Console → Connect)
# El host debe ser algo como ep-mi-proyecto-abc123.sa-east-1.aws.neon.tech
DATABASE_URL=postgresql://neondb_owner:PASSWORD@ep-REEMPLAZAR.region.aws.neon.tech/neondb?sslmode=require

# JWT
JWT_SECRET=tu_secreto_aqui_cambia_esto
JWT_EXPIRES_IN=30d

# Google Sign-In (Web client ID de Google Cloud Console)
GOOGLE_CLIENT_ID=tu_web_client_id.apps.googleusercontent.com
GOOGLE_IOS_CLIENT_ID=tu_ios_client_id.apps.googleusercontent.com
GOOGLE_ANDROID_CLIENT_ID=tu_android_client_id.apps.googleusercontent.com
PIKU_CODIGO_INVITACION=PIKU2025

# Nominatim (geolocalización - servidor de Oracle)
NOMINATIM_BASE_URL=http://167.234.235.76:8080

# Cloudinary (mismas credenciales de GestorNova)
CLOUDINARY_CLOUD_NAME=tu_cloud_name
CLOUDINARY_API_KEY=tu_api_key
CLOUDINARY_API_SECRET=tu_api_secret

# QR dinámico (minutos hasta expiración)
QR_EXPIRACION_MINUTOS=15

# IA — reutilizar Groq de GestorNova (recomendado: proxy sin duplicar clave)
GESTORNOVA_API_URL=https://api-gestornova.onrender.com
# Fallback directo (misma GROQ_API_KEY que GestorNova en Render)
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
